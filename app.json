{
  "expo": {
    "name": "ESP32 Monitor",
    "slug": "esp32",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "esp32monitor",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F1F3F5"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "This app connects to your ESP32 device on your local network for live telemetry and control.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.gabrielrobu.esp32"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F1F3F5"
      },
      "package": "com.gabrielrobu.esp32"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e95bd49-0790-4ea2-a834-e10a4486bf04"
      }
    },
    "owner": "gabrielrobu",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5e95bd49-0790-4ea2-a834-e10a4486bf04"
    }
  }
}
