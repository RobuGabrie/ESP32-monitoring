{
  "expo": {
    "name": "Skydiver Monitor",
    "slug": "esp32",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "skydivermonitor",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F1F3F5"
    },
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyCEwqn84JY4pVDjvZADZu2EjfKZJYz37xM"
      },
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "This app connects to your ESP32 device on your local network for live telemetry and control.",
        "NSBluetoothAlwaysUsageDescription": "This app uses Bluetooth to connect to your wearable device for real-time health monitoring.",
        "NSBluetoothPeripheralUsageDescription": "This app connects to Bluetooth peripherals for wearable device communication.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.gabrielrobu.skydiver"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F1F3F5"
      },
      "package": "com.gabrielrobu.skydiver",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCEwqn84JY4pVDjvZADZu2EjfKZJYz37xM"
        }
      },
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e95bd49-0790-4ea2-a834-e10a4486bf04"
      }
    },
    "owner": "gabrielrobu",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5e95bd49-0790-4ea2-a834-e10a4486bf04"
    }
  }
}
