{
  "expo": {
    "name": "ESP32 Monitor",
    "slug": "esp32-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "esp32monitor",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F1F3F5"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F1F3F5"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
